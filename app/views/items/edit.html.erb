<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing item</h1>

  <%= render "form", list: @list, item: @item %>

  <%= link_to "Show this item", list_item_path(@list, @item), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
  <%= link_to "Back to items", list_items_path(@list), class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
</div>
